  "guidebook": {
    "id": "gb_u1",
    "unitId": "u1",
    "title": "Order food and drink",
    "keyPhrases": [
      {"targetText": "Un café, por favor", "baseText": "A coffee, please", "audioRef": "sha256:476e8b59e0e8ac3cd25a9079614188944feffc85a4942a1fd5009e6f052966d9"},
      {"targetText": "La cuenta, por favor", "baseText": "The check, please", "audioRef": "sha256:476e8b59e0e8ac3cd25a9079614188944feffc85a4942a1fd5009e6f052966d9"},
      {"targetText": "Quiero un té", "baseText": "I want a tea", "audioRef": "sha256:476e8b59e0e8ac3cd25a9079614188944feffc85a4942a1fd5009e6f052966d9"}
    ],
    "tipSections": [
      {
        "heading": "Gendered nouns",
        "bodyMarkdown": "Spanish nouns are masculine or feminine. *El* goes before masculine nouns and *la* before feminine ones.\n\n| Spanish | English |\n| --- | --- |\n| el café | the coffee |\n| la leche | the milk |",
        "examples": [
          {"target": "el café", "base": "the coffee"},
          {"target": "la leche", "base": "the milk"}
        ]
      },
      {
        "heading": "Ordering politely",
        "bodyMarkdown": "Add **por favor** to the end of an order and you are already polite enough for any café in Madrid.",
        "examples": [
          {"target": "Un té, por favor", "base": "A tea, please"}
        ]
      }
    ]
  },
  "stories": [
    {
      "id": "st_u1_1",
      "unitId": "u1",
      "title": "El café de Tama",
      "titleBase": "Tama's café",
      "cefr": "A1",
      "xpReward": 20,
      "characters": [
        {"id": "tama", "name": "Tama", "avatarRef": "cast/tama.svg", "voice": "f1"},
        {"id": "mesero", "name": "El mesero", "avatarRef": "cast/mesero.svg", "voice": "m1"},
        {"id": "ana", "name": "Ana", "avatarRef": "cast/ana.svg", "voice": "f2"}
      ],
      "lines": [
        {"speakerId": "", "targetText": "Tama entra en un café.", "baseText": "Tama walks into a café.", "audioRef": "sha256:476e8b59e0e8ac3cd25a9079614188944feffc85a4942a1fd5009e6f052966d9"},
        {"speakerId": "mesero", "targetText": "¡Hola! ¿Qué quieres?", "baseText": "Hi! What do you want?", "audioRef": "sha256:358c6dcef4442790decb0a5c03fb320154f9d1dd5b4618e301f9e6661a413cb5"},
        {"speakerId": "tama", "targetText": "Un café con leche, por favor.", "baseText": "A coffee with milk, please.", "audioRef": "sha256:7e28a155ec8ae58f8483a9f7dc8d8190173ded11c01b5f31e1c6f8ee629916c6"},
        {"speakerId": "mesero", "targetText": "¿Algo más?", "baseText": "Anything else?", "audioRef": "sha256:358c6dcef4442790decb0a5c03fb320154f9d1dd5b4618e301f9e6661a413cb5"},
        {"speakerId": "tama", "targetText": "Sí, un sándwich.", "baseText": "Yes, a sandwich.", "audioRef": "sha256:7e28a155ec8ae58f8483a9f7dc8d8190173ded11c01b5f31e1c6f8ee629916c6"},
        {"speakerId": "", "targetText": "Ana entra en el café.", "baseText": "Ana walks into the café.", "audioRef": "sha256:476e8b59e0e8ac3cd25a9079614188944feffc85a4942a1fd5009e6f052966d9"},
        {"speakerId": "ana", "targetText": "¡Hola, Tama! ¿Qué tal?", "baseText": "Hi, Tama! How are you?", "audioRef": "sha256:e1882bb0e86ccd4f6e81ac879c35e619512c25b636850d30ea75256ed55d21c6"},
        {"speakerId": "tama", "targetText": "Bien, gracias. ¿Quieres un café?", "baseText": "Fine, thanks. Do you want a coffee?", "audioRef": "sha256:7e28a155ec8ae58f8483a9f7dc8d8190173ded11c01b5f31e1c6f8ee629916c6"},
        {"speakerId": "ana", "targetText": "No, gracias. Quiero un té.", "baseText": "No, thanks. I want a tea.", "audioRef": "sha256:e1882bb0e86ccd4f6e81ac879c35e619512c25b636850d30ea75256ed55d21c6"},
        {"speakerId": "mesero", "targetText": "Un té para la señora.", "baseText": "A tea for the lady.", "audioRef": "sha256:358c6dcef4442790decb0a5c03fb320154f9d1dd5b4618e301f9e6661a413cb5"},
        {"speakerId": "tama", "targetText": "La cuenta, por favor.", "baseText": "The check, please.", "audioRef": "sha256:7e28a155ec8ae58f8483a9f7dc8d8190173ded11c01b5f31e1c6f8ee629916c6"},
        {"speakerId": "", "targetText": "Tama paga y los dos beben juntos.", "baseText": "Tama pays and the two drink together.", "audioRef": "sha256:476e8b59e0e8ac3cd25a9079614188944feffc85a4942a1fd5009e6f052966d9"}
      ],
      "exercises": [
        {"afterLine": 4, "exercise": {"type": "story_choice", "prompt": {"text": "What does Tama order?"}, "options": ["A coffee with milk", "A tea", "A water"], "correctIndex": 0}},
        {"afterLine": 8, "exercise": {"type": "story_choice", "prompt": {"text": "What does Tama offer Ana?"}, "options": ["A coffee", "A sandwich", "The check"], "correctIndex": 0}},
        {"afterLine": 12, "exercise": {"type": "story_choice", "prompt": {"text": "Who pays the check?"}, "options": ["Tama", "Ana", "El mesero"], "correctIndex": 0}}
      ]
    }
  ]
