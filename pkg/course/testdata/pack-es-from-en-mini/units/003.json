      {
        "heading": "Mi and mis",
        "bodyMarkdown": "Use **mi** for one thing and **mis** for several, no matter who owns them.",
        "examples": [
          {"target": "mi hermano", "base": "my brother"},
          {"target": "mis hermanos", "base": "my brothers"}
        ]
      },
      {
        "heading": "Family words come in pairs",
        "bodyMarkdown": "Most family words have a masculine and a feminine form that differ only in the last vowel.\n\n| Masculine | Feminine |\n| --- | --- |\n| el hermano | la hermana |\n| el abuelo | la abuela |\n| el hijo | la hija |",
        "examples": [
          {"target": "la hija", "base": "the daughter"}
        ]
      }
    ]
